{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "declaration": true, // generate .d.ts files
    "emitDeclarationOnly": true, // optional, if you only want types
    "outDir": "dist", // where JS and .d.ts go
    "composite": true,
    "strict": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ]
}
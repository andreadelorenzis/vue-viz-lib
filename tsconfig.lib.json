{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "composite": true,
    "strict": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
